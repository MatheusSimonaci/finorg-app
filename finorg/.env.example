# Banco de dados SQLite (gerado automaticamente pelo Prisma)
DATABASE_URL="file:./prisma/dev.db"

# Seed usado para derivar a chave de criptografia AES-256-GCM do token Vercel.
# Defina uma string aleatória com 32+ caracteres em produção.
TOKEN_STORE_SEED="change-this-to-a-random-secret-in-production"

# OpenAI — necessário apenas na Story 1.3 (classificação por IA)
OPENAI_API_KEY=""

# Vercel — necessário apenas no Epic 7 (snapshot mobile)
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""

# ────────────────────────────────
# Turso (banco de dados em produção)
# Crie sua conta em: https://turso.tech
# Termo de uso: https://turso.tech/legal/tos
# Crie um banco: turso db create finorg-app
# Obtenha o token: turso db tokens create finorg-app
# Em dev local: use TURSO_DATABASE_URL=file:prisma/dev.db (sem TURSO_AUTH_TOKEN)
# ────────────────────────────────
TURSO_DATABASE_URL="file:prisma/dev.db"
TURSO_AUTH_TOKEN=""

# ────────────────────────────────
# WorkOS (autenticação)
# Crie sua conta em: https://workos.com
# Termo de uso: https://workos.com/terms
# Plano Free: até 1M MAU sem custo
# No dashboard WorkOS: crie um app, configure o redirect URI
# Redirect URI para dev: http://localhost:3000/callback
# Redirect URI para prod: https://seu-dominio.vercel.app/callback
# WORKOS_COOKIE_PASSWORD: string aleatória de 32+ caracteres
# Gere com: openssl rand -base64 32
# ────────────────────────────────
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"
# Gere com: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=""

# Cookie Settings — persistência de sessão (IMPORTANTE para evitar auth loops!)
# MAX_AGE em segundos: 604800 = 7 dias, 86400 = 1 dia, 2592000 = 30 dias
# Recomendado: 604800 (7 dias) para UX balanceada entre segurança e conveniência
WORKOS_COOKIE_MAX_AGE=604800
# SameSite: lax (padrão seguro), strict (mais restritivo), none (requer HTTPS)
# Recomendado: lax (permite cookies em navegação normal, bloqueia CSRF)
WORKOS_COOKIE_SAMESITE=lax
# WORKOS_COOKIE_DOMAIN: domínio do cookie (opcional, auto-detectado se omitido)
# Deixe vazio para localhost. Em prod, será auto-detectado pelo Vercel.
# WORKOS_COOKIE_DOMAIN=

# ────────────────────────────────
# Stripe (billing futuro — não necessário agora)
# Crie sua conta em: https://stripe.com
# Termo de uso: https://stripe.com/br/legal/ssa
# ────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
